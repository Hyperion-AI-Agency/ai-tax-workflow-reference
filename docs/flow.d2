# AI Tax System - Processing Flow
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout dagre

shape: sequence_diagram

cpa: CPA {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}
api: FastAPI {
  icon: https://cdn.simpleicons.org/fastapi
}
ocr: OCR Worker {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
}
claude: Claude {
  icon: https://cdn.simpleicons.org/anthropic
}
db: Postgres {
  icon: https://cdn.simpleicons.org/postgresql
}
target: ProConnect / DrakeTax {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
}

cpa -> api: "1. Upload tax return"
api -> ocr: "2. Enqueue OCR"
ocr -> claude: "3. Extract fields"
claude -> db: "4. Persist with confidence scores"
db -> target: "5. Export verified fields" {
  style.stroke: "#059669"
  style.bold: true
}
target -> cpa: "6. Import confirmed"
