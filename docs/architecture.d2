# AI Tax System - Architecture
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout elk

direction: down

cpa: CPA User {
  shape: person
}

web: Web Portal {
  style.font-size: 18
}

api: FastAPI Gateway {
  style.font-size: 18
}

pipeline: "Extraction Pipeline" {
  style.font-size: 18
  style.bold: true

  ocr: OCR Worker
  claude: Claude Extraction
  review: Review Queue {
    shape: queue
  }
}

data: "Data Layer" {
  style.font-size: 18
  style.bold: true

  s3: Encrypted S3 {
    shape: cylinder
  }
  db: Postgres {
    shape: cylinder
  }
}

external: "External Services" {
  style.font-size: 18
  style.bold: true

  textract: AWS Textract {
    shape: cloud
  }
  claude_api: Anthropic Claude {
    shape: cloud
  }
  target: "ProConnect / DrakeTax" {
    shape: cloud
  }
}

cpa -> web: "Upload return"
web -> api
api -> data.s3: "Encrypted upload"
api -> pipeline.ocr: "Enqueue"
pipeline.ocr -> external.textract
pipeline.ocr -> pipeline.claude
pipeline.claude -> external.claude_api
pipeline.claude -> pipeline.review: "Low confidence"
pipeline.claude -> data.db: "High confidence fields"
pipeline.review -> data.db: "After human review"
data.db -> external.target: "Export return"
