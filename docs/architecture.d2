# AI Tax System - Architecture
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout elk

direction: right
grid-columns: 2
grid-gap: 40

classes: {
  card: {
    width: 220
    height: 140
  }
}

cpa: CPA User {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}

web: Next.js Frontend {
  class: card
  icon: https://cdn.simpleicons.org/nextdotjs
}

api: FastAPI Gateway {
  class: card
  icon: https://cdn.simpleicons.org/fastapi
}

pipeline: "Extraction Pipeline" {
  style.bold: true

  ocr: OCR Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
  }
  claude: Claude Extraction {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  review: Review Queue {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/list-checks.svg
  }
}

db: Postgres {
  class: card
  icon: https://cdn.simpleicons.org/postgresql
}

target: "ProConnect / DrakeTax" {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
}

cpa -> web: "1. Upload return"
web -> api: "2. POST /returns"
api -> pipeline.ocr: "3. Enqueue OCR"
pipeline.ocr -> pipeline.claude: "4. Extract fields"
pipeline.claude -> pipeline.review: "5a. Low confidence"
pipeline.claude -> db: "5b. High confidence"
pipeline.review -> db: "6. After review"
api -> db: "7. Read verified"
api -> target: "8. Export"
