# AI Tax System - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 120

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
}

# Row 0: user | app | (empty spacer)
# Row 1: data | extraction | integrations
user_slot: "" {
  style.fill: transparent
  style.stroke: transparent

  cpa: CPA User {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
  }
}

app_zone: "App" {
  grid-columns: 2
  grid-gap: 30

  web: Next.js Upload {
    class: card
    icon: https://cdn.simpleicons.org/nextdotjs
  }
  api: FastAPI {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
}

spacer_1: "" {
  style.fill: transparent
  style.stroke: transparent
}

data_zone: "Data" {
  grid-columns: 2
  grid-gap: 30

  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  storage: S3 (KMS) {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

extraction_zone: "Extraction Pipeline" {
  grid-columns: 3
  grid-gap: 30

  ocr: OCR Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
  }
  extractor: Extraction Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  review: Review Queue {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/list-checks.svg
  }
}

integrations_zone: "3rd Party Integrations" {
  grid-columns: 2
  grid-gap: 30

  claude: Claude API {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  target: ProConnect / DrakeTax {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
  }
}

user_slot.cpa -> app_zone.web: "1. Upload"
app_zone.web -> app_zone.api: "2. POST /returns"
app_zone.api -> data_zone.storage: "3. Store file"
app_zone.api -> data_zone.db: "4. Create job"
data_zone.db -> extraction_zone.ocr: "5. Dequeue"
extraction_zone.ocr -> extraction_zone.extractor: "6. OCR text"
extraction_zone.extractor -> extraction_zone.review: "7. Low-confidence"
extraction_zone -> data_zone.db: "8. Persist verified"
app_zone.api -> integrations_zone.target: "9. Export"
extraction_zone.extractor -> integrations_zone.claude: "LLM call" {
  style.stroke-dash: 3
}
