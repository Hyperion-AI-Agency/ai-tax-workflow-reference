# AI Tax System - Flow (generated from freebie.diagram spec)
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout dagre ... docs/flow.d2 docs/flow.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

shape: sequence_diagram

# --- Participants ---
cpa: CPA {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}
frontend: Next.js Frontend {
  icon: https://cdn.simpleicons.org/nextdotjs
}
backend: FastAPI Backend {
  icon: https://cdn.simpleicons.org/fastapi
}
db: Postgres {
  icon: https://cdn.simpleicons.org/postgresql
}
claude: Claude API {
  icon: https://cdn.simpleicons.org/anthropic
}
target: ProConnect {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
}

# --- Messages ---
cpa -> frontend: "1. Upload return"
frontend -> backend: "2. POST /returns"
backend -> db: "3. Create job (pending)"
backend -> claude: "4. Extract fields"
claude -> backend: "5. Structured JSON + confidence"
backend -> db: "6. Persist verified"
backend -> target: "7. Export" {
  style.stroke: "#059669"
  style.bold: true
}
target -> cpa: "8. Import confirmed"
