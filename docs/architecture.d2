# AI Tax System - Architecture (generated from freebie.diagram spec)
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk ... docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 240

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
  hidden: {
    style.fill: transparent
    style.stroke: transparent
  }
}

# --- Row 0: spacer | entry | spacer-or-observability ---

spacer_tl: "" { class: hidden }

entry_slot: "" { class: hidden
  entry: CPA User {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
  }
}

spacer_tr: "" { class: hidden }

# --- Row 1: data | app | integrations ---

data_zone: "Data" {
  grid-columns: 2
  grid-gap: 80
  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  storage: S3 (KMS) {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

app_zone: "App" {
  grid-columns: 2
  grid-gap: 80
  web: Next.js Frontend {
    class: card
    icon: https://cdn.simpleicons.org/nextdotjs
  }
  api: FastAPI Backend {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
}

integrations_zone: "3rd Party Integrations" {
  grid-columns: 3
  grid-gap: 80
  claude: Claude API {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  proconnect: ProConnect {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
  }
  draketax: DrakeTax {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
  }
}

# --- Row 2: spacer | processing | spacer ---

spacer_bl: "" { class: hidden }

processing_zone: "Extraction Pipeline" {
  grid-columns: 3
  grid-gap: 80
  ocr: OCR Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
  }
  extractor: Extraction Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  review: Review Queue {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/list-checks.svg
  }
}

spacer_br: "" { class: hidden }

# --- Arrows ---
entry_slot.entry -> app_zone.web: "1. Upload"
app_zone.web -> app_zone.api: "2. POST /returns"
app_zone.api -> data_zone.storage: "3. Store file"
app_zone.api -> data_zone.db: "4. Create job"
data_zone.db -> processing_zone.ocr: "5. Dequeue"
processing_zone.ocr -> processing_zone.extractor: "6. OCR text"
processing_zone.extractor -> processing_zone.review: "7. Low-confidence"
processing_zone -> data_zone.db: "8. Persist verified"
app_zone.api -> integrations_zone.proconnect: "9a. Export"
app_zone.api -> integrations_zone.draketax: "9b. Export"
processing_zone.extractor -> integrations_zone.claude: "LLM call" {
  style.stroke-dash: 3
}
