# AI Tax System - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 60

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
}

# Entry point - outside the system
cpa: CPA User {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}

client_zone: "Client" {
  web: Next.js Upload {
    class: card
    icon: https://cdn.simpleicons.org/nextdotjs
  }
}

backend_zone: "Extraction Pipeline" {
  grid-columns: 2
  grid-gap: 40

  api: FastAPI Gateway {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
  ocr: OCR Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/scan-text.svg
  }
  claude: Claude Extraction {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  review: Review Queue {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/list-checks.svg
  }
}

data_zone: "Data" {
  grid-columns: 2
  grid-gap: 40

  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  storage: S3 (KMS) {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

external_zone: "Target Systems" {
  target: ProConnect / DrakeTax {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/file-text.svg
  }
}

# All writes funnel through api (no direct claude/review -> db arrows).
cpa -> client_zone.web: "1. Upload return"
client_zone.web -> backend_zone.api: "2. POST /returns"
backend_zone.api -> data_zone.storage: "3. Store encrypted"
backend_zone.api -> backend_zone.ocr: "4. Enqueue OCR"
backend_zone.ocr -> backend_zone.claude: "5. Extract fields"
backend_zone.claude -> backend_zone.review: "6. Low-confidence"
backend_zone.review -> backend_zone.api: "7. CPA-approved"
backend_zone.api -> data_zone.db: "8. Persist verified"
backend_zone.api -> external_zone.target: "9. Export"
